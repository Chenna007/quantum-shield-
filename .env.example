# ============================================================
# QuantumShield — Environment Variables
# Copy this file to .env and fill in all values
# ============================================================

# ────────────────────────────────────────────────────────────
# BACKEND (.env in /backend)
# ────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://quantumshield:CHANGE_PASSWORD@localhost:5432/quantumshield
POSTGRES_PASSWORD=CHANGE_PASSWORD

# JWT Authentication
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING_64_CHARS_MINIMUM

# Stripe Payments
STRIPE_SECRET_KEY=sk_live_...         # From Stripe Dashboard > Developers > API Keys
STRIPE_PUBLISHABLE_KEY=pk_live_...    # Used in frontend
STRIPE_WEBHOOK_SECRET=whsec_...       # From Stripe Dashboard > Webhooks

# Stripe Price IDs (create these in Stripe Dashboard > Products)
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Email (Admin notifications from contact form)
ADMIN_EMAIL=admin@yourcompany.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your-app-password    # Gmail App Password (not account password)

# ────────────────────────────────────────────────────────────
# FRONTEND (.env.local in /frontend)
# ────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:8000        # or https://api.yourapp.com in prod
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ────────────────────────────────────────────────────────────
# DEPLOYMENT
# ────────────────────────────────────────────────────────────

# Vercel (frontend) — set these in Vercel Dashboard > Project > Environment Variables
# NEXT_PUBLIC_API_URL=https://api.quantumshield.io
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Railway / AWS (backend) — set these in your cloud provider's environment settings
# Same as backend vars above
